{
  "name": "distributed-job-scheduler",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "changeset": "changeset",
    "clean": "pnpm -r --parallel exec rm -rf node_modules .turbo dist .next build && rm -rf node_modules .turbo",
    "commit": "cz",
    "dev": "turbo dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "lint": "turbo lint",
    "prepare": "husky",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "commitizen": "^4.3.2",
    "cz-git": "^1.13.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "packageManager": "pnpm@10.34.4"
}
